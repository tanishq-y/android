{
  "manifest_version": 3,
  "name": "Flit — Quick Commerce Price Comparison",
  "version": "1.0.0",
  "description": "Compares prices across Blinkit, Zepto, Instamart, BigBasket and JioMart using your real session.",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Flit Price Comparison",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "cookies",
    "storage"
  ],

  "host_permissions": [
    "https://blinkit.com/*",
    "https://*.blinkit.com/*",
    "https://www.zeptonow.com/*",
    "https://api.zeptonow.com/*",
    "https://www.zepto.com/*",
    "https://*.zepto.com/*",
    "https://bff-gateway.zepto.com/*",
    "https://www.swiggy.com/*",
    "https://www.bigbasket.com/*",
    "https://www.jiomart.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://flit.app/*",
        "https://www.flit.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "externally_connectable": {
    "matches": [
      "http://localhost:5173/*",
      "https://flit.app/*",
      "https://www.flit.app/*"
    ]
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
