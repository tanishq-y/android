PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flit
# Base64 encoded 32-byte key for AES-256-GCM encryption (example placeholder)
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
TOKEN_KEY_VERSION=1
DEFAULT_DEV_USER_ID=dev-user-001
# Optional local fallback when Postgres is unavailable (development only)
ENABLE_DEV_FILE_VAULT=false
# Return synthetic sample products only when all live platforms fail.
# Keep this false for real app-to-app comparison.
ENABLE_SYNTHETIC_FALLBACK=false
VITE_APP_URL=http://localhost:5173
# Optional API base override for native/mobile builds, e.g. http://192.168.1.10:3001
VITE_API_BASE_URL=
