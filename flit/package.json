{
  "name": "flit",
  "version": "2.0.0",
  "description": "Quick commerce price comparison — Blinkit, Zepto, Instamart, BigBasket, JioMart",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/server.js",
    "migrate": "node server/scripts/migrate.js",
    "keygen:token": "node server/scripts/generateTokenKey.js",
    "dev:lan": "vite --host 0.0.0.0 --port 5173",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npm run build && npx cap run android",
    "start": "concurrently \"npm run dev\" \"npm run server\""
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.383.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "tailwindcss": "^4.0.0",
    "vite": "^7.0.0"
  }
}
